# Anthropic API key — get it from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token with repo scope
# Create at: https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=ghp_...

# GitHub username to watch for issue assignments (default: claudebot)
# Change this to your own GitHub username to test without a separate bot account
BOT_ASSIGNEE=claudebot
